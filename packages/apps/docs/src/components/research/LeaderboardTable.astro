---
import { CATEGORY_LABELS, scoreBand, type LeaderboardEntry } from '~/lib/research-data';

interface Props {
  entries: LeaderboardEntry[];
}

const { entries } = Astro.props;

function hostOf(url: string): string {
  try {
    return new URL(url).host.replace(/^www\./, '');
  } catch {
    return url;
  }
}
---

{entries.length === 0 ? (
  <p class="empty-state">
    No sites scanned yet. Once the first batch lands, the leaderboard will populate here.
  </p>
) : (
  <table class="leaderboard" aria-describedby="leaderboard-desc">
    <caption id="leaderboard-desc" class="sr-only">
      {entries.length} sites ranked by overall a14y score, descending.
    </caption>
    <thead>
      <tr>
        <th scope="col" class="col-rank">#</th>
        <th scope="col" class="col-name">Site</th>
        <th scope="col" class="col-cat">Category</th>
        <th scope="col" class="col-score">Score</th>
        <th scope="col" class="col-fail">Top failures</th>
      </tr>
    </thead>
    <tbody>
      {entries.map((entry, i) => (
        <tr
          class="lb-row"
          data-slug={entry.slug}
          data-name={entry.name.toLowerCase()}
          data-category={entry.category}
          data-score={entry.score}
        >
          <td class="col-rank"><span class="rank">{i + 1}</span></td>
          <td class="col-name">
            <a href={entry.url} rel="nofollow noopener" target="_blank">
              <span class="lb-name">{entry.name}</span>
              <span class="lb-host">{hostOf(entry.url)}</span>
            </a>
          </td>
          <td class="col-cat">
            <span class={`chip cat-${entry.category}`}>{CATEGORY_LABELS[entry.category]}</span>
          </td>
          <td class="col-score">
            <span class={`score-pill score-${scoreBand(entry.score)}`}>{entry.score}</span>
          </td>
          <td class="col-fail">
            {entry.topFailures.length === 0 ? (
              <span class="lb-no-fail">none</span>
            ) : (
              <span class="lb-fails">
                {entry.topFailures.slice(0, 2).map((id) => (
                  <code class="lb-fail-id">{id}</code>
                ))}
                {entry.topFailures.length > 2 && (
                  <span class="lb-fail-more" title={entry.topFailures.slice(2).join(', ')}>
                    +{entry.topFailures.length - 2}
                  </span>
                )}
              </span>
            )}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
)}

<style>
  .empty-state {
    padding: 32px;
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    color: var(--text-muted);
    text-align: center;
  }
  .leaderboard {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  .leaderboard th,
  .leaderboard td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--border);
    text-align: left;
    vertical-align: middle;
  }
  .leaderboard thead th {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 12px;
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom-color: var(--border-strong);
  }
  .leaderboard tbody tr:hover { background: var(--surface-alt); }
  .col-rank {
    width: 48px;
    color: var(--text-subtle);
    font-family: var(--font-mono);
  }
  .col-rank .rank { font-variant-numeric: tabular-nums; }
  .col-name a {
    text-decoration: none;
    color: var(--text);
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
  }
  .col-name a:hover .lb-name { text-decoration: underline; }
  .lb-name { font-weight: 600; letter-spacing: -0.01em; }
  .lb-host { font-family: var(--font-mono); font-size: 12px; color: var(--text-subtle); }
  .col-cat { width: 14ch; }
  .col-score {
    width: 90px;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .score-pill {
    display: inline-block;
    min-width: 44px;
    padding: 4px 10px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    background: var(--surface-alt);
    border: 1px solid var(--border);
    text-align: center;
  }
  .score-excellent {
    color: oklch(0.45 0.13 150);
    border-color: color-mix(in oklch, oklch(0.45 0.13 150) 50%, var(--border));
    background: color-mix(in oklch, oklch(0.45 0.13 150) 8%, var(--surface));
  }
  .score-good {
    color: oklch(0.5 0.10 200);
    border-color: color-mix(in oklch, oklch(0.5 0.10 200) 50%, var(--border));
    background: color-mix(in oklch, oklch(0.5 0.10 200) 8%, var(--surface));
  }
  .score-fair {
    color: oklch(0.55 0.13 75);
    border-color: color-mix(in oklch, oklch(0.55 0.13 75) 50%, var(--border));
    background: color-mix(in oklch, oklch(0.55 0.13 75) 8%, var(--surface));
  }
  .score-poor {
    color: oklch(0.50 0.18 25);
    border-color: color-mix(in oklch, oklch(0.50 0.18 25) 50%, var(--border));
    background: color-mix(in oklch, oklch(0.50 0.18 25) 8%, var(--surface));
  }
  :root[data-theme='dark'] .score-excellent { color: oklch(0.85 0.13 150); }
  :root[data-theme='dark'] .score-good { color: oklch(0.85 0.10 200); }
  :root[data-theme='dark'] .score-fair { color: oklch(0.85 0.13 75); }
  :root[data-theme='dark'] .score-poor { color: oklch(0.80 0.18 25); }

  .col-fail .lb-fails { display: inline-flex; flex-wrap: wrap; gap: 6px; }
  .lb-fail-id {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--surface-alt);
    border: 1px solid var(--border);
    color: var(--text-muted);
  }
  .lb-fail-more {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-subtle);
    cursor: help;
  }
  .lb-no-fail {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-subtle);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .lb-row[hidden] { display: none; }

  @media (max-width: 720px) {
    .col-fail { display: none; }
    .col-cat { width: auto; }
  }
</style>
