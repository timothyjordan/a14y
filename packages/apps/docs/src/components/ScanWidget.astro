---
// Homepage "scan your site" widget. The audit runs entirely client-side via
// @a14y/core (loaded lazily on first scan), routing cross-origin fetches
// through the scan proxy. See src/lib/scan/run-scan.ts.
import {
  listAllScorecards,
  getLatestScorecardVersion,
  isDraftScorecardVersion,
} from '~/lib/scorecard-data';
import '~/styles/scan-results.css';

// Versions are read at build time from @a14y/core, so a newly released
// scorecard appears here automatically on the next docs deploy (the
// deploy-docs workflow rebuilds after each Release). Default to latest stable.
const scorecards = listAllScorecards();
const latestVersion = getLatestScorecardVersion();
---

<section class="scan-band" id="scan" aria-labelledby="scan-heading">
  <div class="scan-inner">
    <div class="scan-head">
      <h2 id="scan-heading">Scan a page now</h2>
      <p class="scan-sub">
        Runs in your browser using the same engine as the CLI for a single
        page, no install required.
      </p>
    </div>

    <form class="scan-form" data-scan-form novalidate>
      <input
        type="url"
        inputmode="url"
        autocomplete="url"
        spellcheck="false"
        class="scan-input"
        data-scan-input
        placeholder="your-site.com"
        aria-label="Site URL to scan"
        required
      />
      <button type="submit" class="btn btn--primary scan-submit" data-scan-submit>Scan</button>
    </form>

    <div class="scan-options">
      <label class="scan-scorecard-label" for="scan-scorecard">Scorecard</label>
      <select id="scan-scorecard" class="scan-scorecard" data-scan-scorecard>
        {scorecards.map((card) => (
          <option value={card.version} selected={card.version === latestVersion}>
            v{card.version}{isDraftScorecardVersion(card.version) ? ' (draft)' : ''}
          </option>
        ))}
      </select>
    </div>

    <p class="scan-privacy">
      Scanned URLs are fetched through an a14y proxy and are not stored.
    </p>

    <p class="scan-status" data-scan-status role="status" aria-live="polite" hidden></p>
    <div class="scan-results" data-scan-results hidden></div>
  </div>
</section>

<script>
  import { initScanWidget } from '../lib/scan/run-scan';
  initScanWidget();
</script>

<!--
  Styles are global (not Astro-scoped) because the results DOM is created at
  runtime in run-scan.ts; scoped styles only attach to build-time markup.
  Every selector is namespaced under .scan-* to avoid leaking.
-->
<style is:global>
  .scan-band {
    /* Full content width so the band's edges line up with the section
       cards below it (main.container--wide is 1120px). */
    margin: 2.5rem 0 0;
    padding: 1.75rem clamp(1rem, 4vw, 2.25rem);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) * 1.5);
    box-shadow: var(--shadow-card);
  }

  .scan-head h2 {
    margin: 0 0 0.35rem;
    font-size: 1.4rem;
  }
  .scan-sub {
    margin: 0;
    max-width: 65ch;
    color: color-mix(in oklch, var(--text) 82%, transparent);
  }

  .scan-form {
    display: flex;
    gap: 0.6rem;
    margin: 1.1rem 0 0.5rem;
    flex-wrap: wrap;
  }
  .scan-input {
    flex: 1 1 18rem;
    min-width: 0;
    padding: 0.65rem 0.85rem;
    font: inherit;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
  }
  .scan-input:focus-visible {
    outline: 2px solid color-mix(in oklch, var(--link) 60%, transparent);
    outline-offset: 1px;
  }
  .scan-submit {
    flex: 0 0 auto;
    padding-inline: 1.5rem;
  }
  .scan-submit.is-busy {
    opacity: 0.65;
    cursor: progress;
  }

  .scan-options {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.6rem;
  }
  .scan-scorecard-label {
    font-size: 0.85rem;
    color: color-mix(in oklch, var(--text) 78%, transparent);
  }
  .scan-scorecard {
    font: inherit;
    font-size: 0.88rem;
    padding: 0.3rem 0.5rem;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
  }
  .scan-scorecard:focus-visible {
    outline: 2px solid color-mix(in oklch, var(--link) 60%, transparent);
    outline-offset: 1px;
  }

  .scan-privacy {
    margin: 0;
    font-size: 0.8rem;
    color: color-mix(in oklch, var(--text) 70%, transparent);
  }

  /* Scan result + status styles live in ~/styles/scan-results.css (imported in
     the frontmatter), shared with the /research/web/ leaderboard drawers. */
</style>
