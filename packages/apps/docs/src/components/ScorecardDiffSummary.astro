---
/**
 * One-line `+N · M bumped · K removed [· → methodology] vs v{latest}` chip
 * rendered on the scorecards index page next to the draft entry. Renders
 * nothing when the draft is verbatim identical to the latest published —
 * that avoids noise before the first contribution lands.
 */
import {
  getDraftDiff,
  getDraftMethodologyDiff,
  getLatestScorecardVersion,
} from '~/lib/scorecard-data';

const diff = getDraftDiff();
const methodologyBump = getDraftMethodologyDiff();
const latest = getLatestScorecardVersion();
const hasAny =
  diff.added.length + diff.bumped.length + diff.removed.length > 0 ||
  methodologyBump !== null;
---

{hasAny && (
  <span class="diff-summary-chip">
    <span class="diff-summary-added">+{diff.added.length} new</span>
    {' · '}
    <span class="diff-summary-bumped">{diff.bumped.length} bumped</span>
    {' · '}
    <span class="diff-summary-removed">−{diff.removed.length} removed</span>
    {methodologyBump && (
      <>
        {' · '}
        <span class="diff-summary-methodology">→ methodology</span>
      </>
    )}
    {' '}vs v{latest}
  </span>
)}

<style>
  .diff-summary-chip {
    display: block;
    margin-top: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-subtle);
    letter-spacing: 0.02em;
  }
  .diff-summary-added { color: var(--scope-page); }
  .diff-summary-bumped { color: var(--signal); }
  .diff-summary-removed { color: var(--text-subtle); }
  .diff-summary-methodology { color: var(--signal); }
</style>
