---
import type { GetStaticPaths } from 'astro';
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';

export const getStaticPaths = (async () => {
  const entries = await getCollection('scoring');
  return entries.map((entry) => ({
    params: { id: entry.data.id },
    props: { entryId: entry.data.id },
  }));
}) satisfies GetStaticPaths;

const { entryId } = Astro.props;
const entry = await getEntry('scoring', entryId);
if (!entry) throw new Error(`Scoring methodology ${entryId} not found`);
const { Content } = await entry.render();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <section class="hero">
    <div class="hero-text" style="grid-column: 1 / -1;">
      <div class="eyebrow">
        <span class="eyebrow-pin">scoring</span>
        <span>algorithm · pinned per scorecard</span>
      </div>
      <h1 class="scoring-title"><code>{entry.data.id}</code></h1>
      <p class="lead">{entry.data.description}</p>
      <div class="meta-row">
        {entry.data.appliesTo.length > 0
          ? entry.data.appliesTo.map((version) => (
              <a class="chip" href={`${base}/scorecards/${version}/`}>pinned by v{version}</a>
            ))
          : <span class="chip">not currently pinned by any scorecard</span>}
      </div>
    </div>
  </section>

  <Content />

  <p class="lead" style="margin-top: 32px;">
    See <a href={`${base}/scorecards/scoring/`}>all scoring methodologies</a> or
    <a href={`${base}/scorecards/`}>browse scorecards</a> to see which methodology
    each version pins.
  </p>
</BaseLayout>
