---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '~/layouts/BaseLayout.astro';
import CheckCard from '~/components/CheckCard.astro';
import DraftScorecardBanner from '~/components/DraftScorecardBanner.astro';
import ScorecardDiff from '~/components/ScorecardDiff.astro';
import {
  listAllScorecards,
  getScorecardByVersion,
  getChecksGroupedByCategory,
  getDraftScorecardVersion,
  isDraftScorecardVersion,
} from '~/lib/scorecard-data';

export const getStaticPaths = (() => {
  const draftVersion = getDraftScorecardVersion();
  const paths = listAllScorecards().map((card) => ({
    params: { version: card.version },
  }));
  // Friendly alias: /scorecards/draft/ resolves to whichever -draft version
  // is current. Both URLs render the same page.
  paths.push({ params: { version: 'draft' }, props: { resolvedVersion: draftVersion } });
  return paths;
}) satisfies GetStaticPaths;

const { version } = Astro.params;
const resolvedVersion = (Astro.props.resolvedVersion as string | undefined) ?? version!;
const scorecard = getScorecardByVersion(resolvedVersion);
const groups = getChecksGroupedByCategory(resolvedVersion);
const siteGroups = groups.filter((g) => g.scope === 'site');
const pageGroups = groups.filter((g) => g.scope === 'page');
const totalChecks = scorecard.siteChecks.length + scorecard.pageChecks.length;
const isDraft = isDraftScorecardVersion(scorecard.version);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={`Scorecard v${scorecard.version} · a14y`} scorecardVersion={scorecard.version} showVersionSelector>
  {isDraft && <DraftScorecardBanner />}
  {isDraft && <ScorecardDiff draftVersion={scorecard.version} />}
  <h1>Scorecard v{scorecard.version}</h1>
  <p class="lead">{scorecard.description}</p>
  <div class="meta-row">
    {isDraft
      ? <span class="chip">unreleased</span>
      : <span class="chip">released {scorecard.releasedAt}</span>}
    <span class="chip">{totalChecks} checks</span>
    <span class="chip site">{scorecard.siteChecks.length} site-level</span>
    <span class="chip page">{scorecard.pageChecks.length} page-level</span>
    <a class="chip chip-scoring" href={`${base}/scorecards/scoring/${scorecard.scoringMethodology}/`}>scoring: <code>{scorecard.scoringMethodology}</code></a>
  </div>

  <h2>Site checks</h2>
  <p class="lead">
    Evaluated once per audit against the site's origin. These cover discoverability
    surfaces: llms.txt, robots.txt, sitemaps, and agent skill files.
  </p>
  {siteGroups.map((group) => (
    <section class="group-section">
      <h2>
        {group.group} <span class="count">· {group.checks.length} check{group.checks.length === 1 ? '' : 's'}</span>
      </h2>
      <ul class="check-list">
        {group.checks.map((check) => (
          <li><CheckCard check={check} scorecardVersion={scorecard.version} /></li>
        ))}
      </ul>
    </section>
  ))}

  <h2>Page checks</h2>
  <p class="lead">
    Evaluated for every discovered page. These cover HTTP basics, HTML metadata,
    structured data, content structure, markdown mirrors, code blocks, and APIs.
  </p>
  {pageGroups.map((group) => (
    <section class="group-section">
      <h2>
        {group.group} <span class="count">· {group.checks.length} check{group.checks.length === 1 ? '' : 's'}</span>
      </h2>
      <ul class="check-list">
        {group.checks.map((check) => (
          <li><CheckCard check={check} scorecardVersion={scorecard.version} /></li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>
