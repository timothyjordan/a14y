---
import { getEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import {
  getDraftScorecard,
  getLatestScorecardVersion,
  listPublishedScorecards,
} from '~/lib/scorecard-data';

const intro = await getEntry('pages', 'scorecards-intro');
const tail = await getEntry('pages', 'scorecards-tail');
if (!intro || !tail) throw new Error('Missing scorecards content entries');
const { Content: IntroContent } = await intro.render();
const { Content: TailContent } = await tail.render();

const cards = listPublishedScorecards();
const draft = getDraftScorecard();
const latest = getLatestScorecardVersion();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={intro.data.title}>
  <section class="hero">
    <div class="hero-text" style="grid-column: 1 / -1;">
      <div class="eyebrow">
        <span class="eyebrow-pin">scorecards</span>
        <span>frozen manifests · trend cleanly forever</span>
      </div>
      <h1>Scorecards</h1>
      <p class="lead">
        Every shipped scorecard. Each version pins each stable check id to a specific
        implementation. Older versions stay reproducible forever so historical scores
        can be trended consistently.
      </p>
    </div>
  </section>

  <IntroContent />

  <h2>Shipped versions</h2>
  <ul class="check-list">
    {cards.map((card) => (
      <li>
        <a class="check-card" href={`${base}/scorecards/${card.version}/`}>
          <span class="name">v{card.version}{card.version === latest ? ' (latest)' : ''}</span>
          <span class="desc">{card.description}</span>
          <span class="id">
            released {card.releasedAt} · {Object.keys(card.checks).length} checks pinned
          </span>
        </a>
      </li>
    ))}
  </ul>

  {draft && (
    <>
      <h2>Draft</h2>
      <p class="lead">
        The next planned scorecard, in flight. Subject to change. PRs proposing new
        checks or revisions land here — see
        <a href="https://github.com/timothyjordan/a14y/blob/main/CONTRIBUTING.md#scorecard-lifecycle" rel="noopener">
          CONTRIBUTING.md
        </a>.
      </p>
      <ul class="check-list">
        <li>
          <a class="check-card" href={`${base}/scorecards/draft/`}>
            <span class="name">v{draft.version} (draft)</span>
            <span class="desc">{draft.description}</span>
            <span class="id">
              unreleased · {Object.keys(draft.checks).length} checks pinned
            </span>
          </a>
        </li>
      </ul>
    </>
  )}

  <TailContent />
</BaseLayout>
