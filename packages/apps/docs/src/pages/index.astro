---
import { getEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getLatestScorecardVersion, getCheckSummariesForScorecard } from '~/lib/scorecard-data';

const entry = await getEntry('pages', 'index');
if (!entry) throw new Error('Missing pages/index content entry');
const { Content } = await entry.render();

const latest = getLatestScorecardVersion();
const latestChecks = getCheckSummariesForScorecard(latest);
const totalChecks = latestChecks.length;

const installCmd = 'npm install -g a14y';
const runCmd = 'npx a14y your-site.com';
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  wide
>
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-text">
      <div class="eyebrow">
        <span class="eyebrow-pin">v{latest}</span>
        <span>Open spec · {totalChecks} versioned checks</span>
      </div>
      <h1 id="hero-heading">Agent readability for the web</h1>
      <p class="lead">
        Agents now read most of the web before humans do. a14y is the
        open spec, the versioned scorecard, and the tools to score how
        well they can.
      </p>
      <div class="cta-stack" role="group" aria-label="Try a14y">
        <span class="copy-cli copy-cli--block">
          <span class="copy-cli-label">install</span>
          <span class="cmd">{installCmd}</span>
          <button
            type="button"
            class="copy-btn"
            data-copy={installCmd}
            aria-label="Copy install command"
          >Copy</button>
        </span>
        <span class="copy-cli copy-cli--block">
          <span class="copy-cli-label">run once</span>
          <span class="cmd">{runCmd}</span>
          <button
            type="button"
            class="copy-btn"
            data-copy={runCmd}
            aria-label="Copy run command"
          >Copy</button>
        </span>
        <a class="btn btn--ghost cta-spec" href="/spec/">
          Read the spec →
        </a>
      </div>
    </div>

    <aside class="agent-panel" aria-label="What an agent sees on a14y.dev">
      <pre class="agent-output" aria-label="Sample CLI output"><span class="ag-prompt">%</span> a14y https://a14y.dev
<span class="ag-pass">✔</span> Score: 92/100

Agent Readability Score: 92/100
  scorecard 0.2.0 (released 2026-04-06) — mode page
  33 pass · 3 fail · 0 warn · 0 error · 2 n/a (out of 38)

Site checks
  Discoverability
    <span class="ag-pass">✓</span> llms-txt.exists             <span class="ag-mute">site</span>
    <span class="ag-pass">✓</span> robots-txt.allows-ai-bots   <span class="ag-mute">site</span>
    <span class="ag-pass">✓</span> sitemap-md.has-structure    <span class="ag-mute">site</span>
    <span class="ag-pass">✓</span> agents-md.has-min-sections  <span class="ag-mute">site</span>

Page checks — https://a14y.dev/
  HTML metadata
    <span class="ag-pass">✓</span> html.canonical-link         <span class="ag-mute">page</span>
    <span class="ag-pass">✓</span> html.lang-attribute (en)    <span class="ag-mute">page</span>
  Structured data
    <span class="ag-pass">✓</span> html.json-ld.breadcrumb     <span class="ag-mute">page</span>
  Markdown mirror
    <span class="ag-pass">✓</span> markdown.mirror-suffix      <span class="ag-mute">page</span>
    <span class="ag-fail">✗</span> markdown.canonical-header   <span class="ag-mute">page</span>
    <span class="ag-fail">✗</span> markdown.content-negotiation <span class="ag-mute">page</span>
  Code
    <span class="ag-fail">✗</span> code.language-tags          <span class="ag-mute">page</span></pre>
    </aside>
  </section>

  <Content />
</BaseLayout>
