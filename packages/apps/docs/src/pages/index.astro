---
import BaseLayout from '~/layouts/BaseLayout.astro';
import {
  getLatestScorecardVersion,
  getScorecardByVersion,
  getCheckSummariesForScorecard,
} from '~/lib/scorecard-data';
import { buildBadgeHtml } from '~/lib/build-badge-html';
import type { BadgeData } from '@a14y/core';

const latest = getLatestScorecardVersion();
const released = getScorecardByVersion(latest).releasedAt;
const totalChecks = getCheckSummariesForScorecard(latest).length;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const installCmd = 'npm install -g a14y';
const runCmd = 'npx a14y your-site.com';
const skillInstallCmd = 'npx skills add timothyjordan/a14y';

// Hero badge — a14y.dev's own readability score, rendered at build time
// from the same `buildBadgeHtml` powering /badge/. Values mirror the
// summary the CLI prints when run against the live site so the hero
// stays truthful. Both palettes are emitted; CSS hides the one that
// doesn't match the current `[data-theme]`.
const heroBadgeBase = {
  score: 92,
  scorecardVersion: latest,
  applicable: 36,
  total: 38,
  passed: 33,
  failed: 3,
  warned: 0,
  errored: 0,
  na: 2,
  date: released.slice(0, 10),
  mode: 'site' as const,
  url: 'https://a14y.dev/',
};
const heroBadgeLightHtml = buildBadgeHtml({ ...heroBadgeBase, theme: 'light' } satisfies BadgeData);
const heroBadgeDarkHtml = buildBadgeHtml({ ...heroBadgeBase, theme: 'dark' } satisfies BadgeData);
---

<BaseLayout
  title="a14y · agent readability for the web"
  description="Agent readability for the web. An open spec, a versioned scorecard, and the tools (CLI plus Chrome extension) that score any website for how well AI agents can discover, parse, and comprehend it."
  wide
>
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-text">
      <div class="eyebrow">
        <span class="eyebrow-pin">v{latest}</span>
        <span>Open spec · {totalChecks} versioned checks</span>
      </div>
      <h1 id="hero-heading">Agent readability for the web</h1>
      <p class="lead">
        Agents now read most of the web before humans do. a14y is the
        open spec, the versioned scorecard, and the tools to score how
        well they can.
      </p>
      <div class="cta-stack" role="group" aria-label="Try a14y">
        <span class="copy-cli copy-cli--block">
          <span class="copy-cli-label">install</span>
          <span class="cmd">{installCmd}</span>
          <button
            type="button"
            class="copy-btn"
            data-copy={installCmd}
            aria-label="Copy install command"
          >Copy</button>
        </span>
        <span class="copy-cli copy-cli--block">
          <span class="copy-cli-label">run once</span>
          <span class="cmd">{runCmd}</span>
          <button
            type="button"
            class="copy-btn"
            data-copy={runCmd}
            aria-label="Copy run command"
          >Copy</button>
        </span>
        <span class="copy-cli copy-cli--block">
          <span class="copy-cli-label">agent skill</span>
          <span class="cmd">{skillInstallCmd}</span>
          <button
            type="button"
            class="copy-btn"
            data-copy={skillInstallCmd}
            aria-label="Copy agent skill install command"
          >Copy</button>
        </span>
        <a class="btn btn--ghost cta-spec" href={`${base}/spec/`}>
          Read the spec →
        </a>
      </div>
    </div>

    <aside class="hero-badge" aria-label="a14y.dev's own readability score">
      <span class="hero-badge-variant hero-badge-variant--light">
        <Fragment set:html={heroBadgeLightHtml} />
      </span>
      <span class="hero-badge-variant hero-badge-variant--dark" aria-hidden="true">
        <Fragment set:html={heroBadgeDarkHtml} />
      </span>
      <a class="hero-badge-link" href={`${base}/badge/`}>Embed your own →</a>
    </aside>
  </section>

  <hr class="section-rule" aria-hidden="true" />

  <section class="section section--tight" aria-labelledby="steps-heading">
    <div class="section-head">
      <h2 id="steps-heading">Three steps to an agent-readable site</h2>
      <p class="section-sub">
        Score it, fix it, prove it. The same loop works in your
        terminal, your browser, or your coding agent — backed by an
        <a href={`${base}/spec/`}>open spec</a> and a versioned
        <a href={`${base}/scorecards/${latest}/`}>scorecard</a>.
      </p>
    </div>

    <ol class="steps">
      <li class="step-card">
        <span class="step-num">01</span>
        <h3>Run the scorecard</h3>
        <p>
          From the <a href="#tools">CLI</a>, the
          {' '}<a href={`${base}/chrome-extension/`}>Chrome extension</a>,
          or by handing the job to a coding agent with the a14y skill.
          Same engine, same score.
        </p>
      </li>
      <li class="step-card">
        <span class="step-num">02</span>
        <h3>Fix what failed</h3>
        <p>
          Every failing check links to its detection rule and a fix.
          Pipe <code>--output agent-prompt</code> into a coding agent
          to ship the changes as a PR.
        </p>
      </li>
      <li class="step-card">
        <span class="step-num">03</span>
        <h3>Re-run &amp; share</h3>
        <p>
          Run again to confirm the score climbed, then
          {' '}<a href={`${base}/badge/`}>embed your badge</a> so
          agents (and humans) know your site is ready.
        </p>
      </li>
    </ol>

    <p class="steps-skill-callout">
      Or skip the manual loop —
      {' '}<a href="#automate">install the agent skill</a> and a coding
      agent runs all three steps for you.
    </p>
  </section>

  <section id="tools" class="section" aria-labelledby="tools-heading">
    <div class="section-head">
      <h2 id="tools-heading">Run the scorecard yourself</h2>
      <p class="section-sub">
        Same engine, two surfaces. Both produce the same score for the
        same URL and scorecard version.
      </p>
    </div>

    <div class="tools">
      <article class="tool-card">
        <div class="tool-head">
          <span class="tool-badge" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 17 10 11 4 5" />
              <line x1="12" y1="19" x2="20" y2="19" />
            </svg>
          </span>
          <h3>CLI</h3>
        </div>
        <p class="tool-desc">
          Audit any page or whole site from your terminal. Outputs a
          scored text report, JSON, or a Markdown fix-list ready to
          hand to a coding agent.
        </p>
        <pre class="tool-cmd"><code class="language-shell"><span class="prompt">%</span> npm install -g a14y
<span class="prompt">%</span> a14y your-site.com</code></pre>
        <div class="tool-actions">
          <a class="btn btn--primary" href="https://www.npmjs.com/package/a14y" rel="noopener">Install from npm →</a>
          <a class="btn btn--ghost" href="https://github.com/timothyjordan/a14y" rel="noopener">GitHub →</a>
        </div>
      </article>

      <article class="tool-card">
        <div class="tool-head">
          <span class="tool-badge" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 3a9 9 0 0 1 7.8 4.5H12" />
              <path d="M3.5 8.5 7.5 15" />
              <circle cx="12" cy="12" r="3" />
            </svg>
          </span>
          <h3>Chrome Extension</h3>
        </div>
        <p class="tool-desc">
          Score any page you are looking at, right in the browser.
          Switch scorecard versions from the popup, jump straight to
          the failing check&apos;s fix guidance.
        </p>
        <div class="tool-actions">
          <a class="btn btn--primary" href={`${base}/chrome-extension/`}>
            Install →
          </a>
          <a class="btn btn--ghost" href="https://github.com/timothyjordan/a14y/tree/main/packages/apps/extension" rel="noopener">View source →</a>
        </div>
        <p class="tool-note">Chrome Web Store review pending. For now, grab the latest <code>.zip</code> from <a href={`${base}/chrome-extension/`}>the install page</a>.</p>
      </article>

      <article class="tool-card">
        <div class="tool-head">
          <span class="tool-badge" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3 4 7l8 4 8-4-8-4z" />
              <path d="m4 12 8 4 8-4" />
              <path d="m4 17 8 4 8-4" />
            </svg>
          </span>
          <h3>Coding agent skill</h3>
        </div>
        <p class="tool-desc">
          A spec-compliant <a href="https://agentskills.io/specification" rel="noopener">agent skill</a> that
          wraps the CLI: detects a local dev server, runs the audit,
          proposes a fix plan, and tracks score deltas. Works with
          Claude Code, Codex, Cursor, and any other coding agent that
          supports the open skills format.
        </p>
        <pre class="tool-cmd"><code class="language-shell"><span class="prompt">%</span> {skillInstallCmd}</code></pre>
        <div class="tool-actions">
          <button
            type="button"
            class="btn btn--primary"
            data-copy={skillInstallCmd}
            aria-label="Copy install command"
          >Copy install →</button>
        </div>
        <p class="tool-note">Discoverable via <code>&lt;link rel="agent-skills"&gt;</code> on every page of this site.</p>
      </article>
    </div>
  </section>

  <section id="automate" class="section" aria-labelledby="automate-heading">
    <div class="section-head">
      <h2 id="automate-heading">Update your site the easy way</h2>
      <p class="section-sub">
        Both paths produce the same score. Pick the one that matches
        how you ship: write your own coding-agent prompt, or let the
        skill drive the whole loop.
      </p>
    </div>

    <div class="automate-grid">
      <article class="automate-card">
        <span class="automate-eyebrow">Path A · bring your own agent</span>
        <h3>Markdown fix-list from the CLI or extension</h3>
        <p>
          Run with <code>--output agent-prompt</code> in the CLI, or
          hit <strong>Share → Agent prompt</strong> in the extension.
          Paste the Markdown into Claude Code, Codex, Cursor, or any
          agent that takes a prompt.
        </p>
        <pre class="automate-cmd"><code class="language-shell"><span class="prompt">%</span> a14y your-site.com --output agent-prompt</code></pre>
        <div class="automate-actions">
          <a class="btn btn--ghost" href="https://www.npmjs.com/package/a14y" rel="noopener">CLI on npm →</a>
          <a class="btn btn--ghost" href={`${base}/chrome-extension/`}>Chrome extension →</a>
        </div>
      </article>

      <article class="automate-card automate-card--feature">
        <span class="automate-eyebrow">Path B · agent on rails</span>
        <h3>The a14y skill runs the whole loop</h3>
        <p>
          Install once. Then in any coding session: the skill detects
          your local dev server, runs the audit, proposes a prioritized
          fix plan, ships the changes, and re-runs to confirm the
          score went up.
        </p>
        <pre class="automate-cmd"><code class="language-shell"><span class="prompt">%</span> {skillInstallCmd}</code></pre>
        <div class="automate-actions">
          <button
            type="button"
            class="btn btn--primary"
            data-copy={skillInstallCmd}
            aria-label="Copy install command"
          >Copy install →</button>
          <a class="btn btn--ghost" href="https://github.com/timothyjordan/a14y" rel="noopener">Star on GitHub ★</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
