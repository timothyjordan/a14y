---
import BaseLayout from '~/layouts/BaseLayout.astro';
import LeaderboardTable from '~/components/research/LeaderboardTable.astro';
import ScoreHistogram from '~/components/research/ScoreHistogram.astro';
import CategoryBars from '~/components/research/CategoryBars.astro';
import CheckPassRates from '~/components/research/CheckPassRates.astro';
import {
  CATEGORY_LABELS,
  getCategoryStats,
  getHardestChecks,
  getLeaderboard,
  getLlmsTxtAdoption,
  getMostCommonTopFailure,
  getResearchData,
  getScoreHistogram,
  type SiteCategory,
} from '~/lib/research-data';

const research = getResearchData();
const entries = getLeaderboard();
const hist = getScoreHistogram();
const catStats = getCategoryStats();
const hardestChecks = getHardestChecks();
const llms = getLlmsTxtAdoption();
const mostCommonFailure = getMostCommonTopFailure();

const categoriesPresent: SiteCategory[] = Array.from(
  new Set(entries.map((e) => e.category)),
).sort();

const generated = new Date(research.generatedAt);
const generatedLabel = isNaN(generated.getTime())
  ? '—'
  : generated.toISOString().slice(0, 10);

const meanScore = entries.length
  ? Math.round((entries.reduce((s, e) => s + e.score, 0) / entries.length) * 10) / 10
  : 0;
---

<BaseLayout
  title="Research — leaderboard of how AI agents see the web"
  description="A scored leaderboard of major websites measured for agent readability with the open a14y scorecard. Find which docs platforms, SaaS products, and consumer sites AI agents can actually parse."
  wide={true}
>
  <section class="hero">
    <div class="hero-text" style="grid-column: 1 / -1;">
      <div class="eyebrow">
        <span class="eyebrow-pin">research</span>
        <span>scorecard v{research.scorecardVersion} · updated {generatedLabel}</span>
      </div>
      <h1>How well do agents see the web?</h1>
      <p class="lead">
        We score a curated cross-section of websites with the
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/scorecards/`}>a14y scorecard</a>
        and publish the results here. Use the leaderboard to compare platforms,
        and the insights below to see which scorecard checks are hardest to pass
        across the web.
      </p>
    </div>
  </section>

  <section class="research-summary">
    <p>
      Most of the web was built for human eyes. AI agents — coding assistants,
      research bots, autonomous tools — have to fetch the same pages and pull
      meaning out of layout-driven HTML, JavaScript-rendered widgets, cookie
      walls, and broken markdown. The
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/scorecards/`}>a14y
      scorecard</a> turns that effort into a number: how many of {38} machine-
      readability checks does a site pass, from <code>llms.txt</code> through
      <code>AGENTS.md</code> down to canonical headers and breadcrumb JSON-LD.
      The leaderboard below is what happens when we run those checks against
      the {entries.length} sites in our public catalog. The headline is that
      the median site barely clears halfway: there's a lot of low-hanging
      fruit out there for any team that cares to pick it. The biggest
      adoption gap isn't a fancy semantic feature — it's the three flat files
      that take an hour to ship.
    </p>
  </section>

  <section class="research-stats">
    <div class="stat">
      <span class="stat-value">{entries.length}</span>
      <span class="stat-label">sites scanned</span>
    </div>
    <div class="stat">
      <span class="stat-value">{meanScore}</span>
      <span class="stat-label">mean score</span>
    </div>
    <div class="stat">
      <span class="stat-value">{llms.pct}%</span>
      <span class="stat-label">ship llms.txt</span>
    </div>
    <div class="stat">
      <span class="stat-value stat-value--mono">
        {mostCommonFailure ? mostCommonFailure.checkId : '—'}
      </span>
      <span class="stat-label">most common top failure</span>
    </div>
  </section>

  <section class="research-section">
    <header class="section-header">
      <h2>Leaderboard</h2>
      <div class="filter-bar" data-research-filter>
        <label class="search">
          <span class="sr-only">Search by name</span>
          <input
            type="search"
            placeholder="Filter by name…"
            data-filter-name
            autocomplete="off"
          />
        </label>
        <div class="cat-toggles" role="group" aria-label="Category filter">
          {categoriesPresent.map((cat) => (
            <label class="cat-toggle">
              <input type="checkbox" value={cat} data-filter-cat checked />
              <span>{CATEGORY_LABELS[cat]}</span>
            </label>
          ))}
        </div>
        <button type="button" class="filter-reset" data-filter-reset hidden>
          Reset filters
        </button>
      </div>
    </header>
    <p class="visible-count" data-visible-count>
      Showing {entries.length} of {entries.length} sites.
    </p>
    <p class="filter-empty" data-filter-empty hidden role="status">
      No sites match your filters. <button type="button" data-filter-reset-link>Reset filters</button>.
    </p>
    <LeaderboardTable entries={entries} />
  </section>

  <section class="research-section">
    <h2>Score distribution</h2>
    <p class="section-lead">
      How are the {entries.length} scores distributed across the catalog? Each
      bar counts the sites whose overall score falls in that 10-point bucket.
      Most sites cluster between 40 and 70 — the long climb to a high score
      starts only once a site ships <code>llms.txt</code>, an
      <code>AGENTS.md</code>, and a markdown sitemap, the three site-level
      checks that a single template change can flip from failing to passing.
    </p>
    <ScoreHistogram buckets={hist} />
  </section>

  <section class="research-section">
    <h2>Mean score by category</h2>
    <p class="section-lead">
      Docs platforms tend to score the highest because their authors think
      hardest about machine consumers — many already ship <code>llms.txt</code>
      and an <code>AGENTS.md</code>. Consumer sites like news, retail, and
      reference sit at the bottom: they were built for human eyes, hide
      content behind cookie banners and JavaScript, and rarely surface the
      machine-readable signals an agent needs to navigate them.
    </p>
    <CategoryBars stats={catStats} />
  </section>

  <section class="research-section">
    <h2>Hardest checks to pass</h2>
    <p class="section-lead">
      For each check id, the percentage of sites where the check fully passed
      (every occurrence across every page returned <code>pass</code>). Sorted
      hardest first; filtered to checks applicable to ≥5 sites. The pile-up
      of zeroes and single-digit pass rates near the top is the most
      actionable list on this page — they're the cheapest scorecard wins
      every site is leaving on the table.
    </p>
    <CheckPassRates rows={hardestChecks} />
  </section>

  <section class="research-section research-method">
    <h2>How this leaderboard is built</h2>

    <h3>Scoring</h3>
    <p>
      Every site is scanned with the open-source
      <a href="https://www.npmjs.com/package/a14y" rel="noopener">a14y CLI</a>
      pinned to scorecard <code>v{research.scorecardVersion}</code>. Each site
      gets one site-mode crawl (≤50 pages, polite-delayed) or a single
      page-mode audit for very large consumer sites where crawling every page
      would be wasteful or hostile. The score is the simple ratio
      <code>passed / applicable</code> across every check on every page —
      the same number the CLI prints when you run it locally, so a site
      owner's local result matches the leaderboard exactly.
    </p>

    <h3>Catalog</h3>
    <p>
      The site list is hand-curated with deliberate ratios: at least half are
      technical documentation platforms (React, Stripe, AWS, etc.); at least a
      quarter are non-developer SaaS dashboards and help centers (Notion,
      Slack, Atlassian help); the rest are major consumer sites
      (Wikipedia, news, retail) audited in page mode so a single scan stays
      bounded. Want yours included?
      <a href="https://github.com/timothyjordan/a14y/issues/new?title=Add%20site%20to%20research%20catalog">Open an issue</a>.
    </p>

    <h3>Versioning</h3>
    <p>
      Scores from different scorecard versions are not directly comparable.
      When we ship a new scorecard version, every site is re-scanned against
      it before this page updates, so the leaderboard you're reading today
      compares apples to apples even as the scorecard itself evolves over
      time.
    </p>
  </section>
</BaseLayout>

<style>
  .research-summary {
    margin: 28px 0 36px;
    padding: 22px 26px;
    background: var(--surface-alt);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  .research-summary p {
    margin: 0;
    color: var(--text-muted);
    max-width: 78ch;
    font-size: 15px;
    line-height: 1.65;
  }

  .research-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
    margin: 24px 0 32px;
  }
  .stat {
    background: var(--surface-alt);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .stat-value {
    font-family: var(--font-mono);
    font-size: 24px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    overflow-wrap: anywhere;
  }
  .stat-value--mono {
    font-size: 16px;
    line-height: 1.3;
  }
  .stat-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-subtle);
  }

  .research-section {
    margin-top: 56px;
  }
  .research-section h2 {
    margin-bottom: 8px;
  }
  .research-method h3 {
    margin-top: 24px;
    margin-bottom: 6px;
    font-size: 17px;
    letter-spacing: -0.01em;
  }
  .research-method h3:first-of-type {
    margin-top: 4px;
  }
  .section-lead {
    margin-top: 0;
    margin-bottom: 18px;
    color: var(--text-muted);
    max-width: 72ch;
  }
  .section-header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }
  .section-header h2 { margin: 0; }
  .filter-bar {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .search input {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 6px 10px;
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--text);
    min-width: 18ch;
  }
  .search input:focus {
    outline: 2px solid color-mix(in oklch, var(--brand-ink) 30%, transparent);
    border-color: var(--border-strong);
  }
  .cat-toggles { display: inline-flex; flex-wrap: wrap; gap: 6px; }
  .cat-toggle {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    background: var(--surface);
    cursor: pointer;
    user-select: none;
  }
  .cat-toggle:hover { border-color: var(--border-strong); }
  .cat-toggle input { accent-color: var(--brand-ink); }
  .filter-reset {
    appearance: none;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 4px 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    cursor: pointer;
  }
  .filter-reset:hover {
    border-color: var(--border-strong);
    color: var(--text);
  }
  .visible-count {
    margin: 0 0 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-subtle);
  }
  .filter-empty {
    margin: 8px 0 16px;
    padding: 18px 20px;
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    color: var(--text-muted);
    font-size: 14px;
  }
  .filter-empty button {
    appearance: none;
    background: transparent;
    border: none;
    padding: 0;
    font: inherit;
    color: var(--text);
    text-decoration: underline;
    cursor: pointer;
  }
  .research-method p {
    color: var(--text-muted);
    max-width: 72ch;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script is:inline>
  // Vanilla JS: filter the leaderboard rows by name + category, surface
  // an empty state + reset button when nothing matches. No framework
  // runtime — the table is rendered statically; we only toggle visibility
  // and a couple of sibling messages.
  (function () {
    var bar = document.querySelector('[data-research-filter]');
    if (!bar) return;
    var nameInput = bar.querySelector('[data-filter-name]');
    var catBoxes = bar.querySelectorAll('[data-filter-cat]');
    var resetBtn = bar.querySelector('[data-filter-reset]');
    var emptyMsg = document.querySelector('[data-filter-empty]');
    var emptyResetLink = emptyMsg && emptyMsg.querySelector('[data-filter-reset-link]');
    var rows = Array.prototype.slice.call(document.querySelectorAll('.lb-row'));
    var counter = document.querySelector('[data-visible-count]');
    var totalRows = rows.length;

    function defaultsActive() {
      if (nameInput && nameInput.value) return false;
      for (var i = 0; i < catBoxes.length; i++) if (!catBoxes[i].checked) return false;
      return true;
    }

    function apply() {
      var q = (nameInput && nameInput.value || '').trim().toLowerCase();
      var allowed = Object.create(null);
      catBoxes.forEach(function (cb) { if (cb.checked) allowed[cb.value] = true; });
      var visible = 0;
      rows.forEach(function (row) {
        var name = row.getAttribute('data-name') || '';
        var cat = row.getAttribute('data-category') || '';
        var ok = (q === '' || name.indexOf(q) >= 0) && allowed[cat];
        if (ok) {
          row.removeAttribute('hidden');
          visible++;
        } else {
          row.setAttribute('hidden', 'hidden');
        }
      });
      if (counter) {
        counter.textContent = 'Showing ' + visible + ' of ' + totalRows + ' sites.';
      }
      if (emptyMsg) {
        if (visible === 0) emptyMsg.removeAttribute('hidden');
        else emptyMsg.setAttribute('hidden', 'hidden');
      }
      if (resetBtn) {
        if (defaultsActive()) resetBtn.setAttribute('hidden', 'hidden');
        else resetBtn.removeAttribute('hidden');
      }
    }

    function reset() {
      if (nameInput) nameInput.value = '';
      catBoxes.forEach(function (cb) { cb.checked = true; });
      apply();
      if (nameInput) nameInput.focus();
    }

    if (nameInput) nameInput.addEventListener('input', apply);
    catBoxes.forEach(function (cb) { cb.addEventListener('change', apply); });
    if (resetBtn) resetBtn.addEventListener('click', reset);
    if (emptyResetLink) emptyResetLink.addEventListener('click', reset);
  })();
</script>
