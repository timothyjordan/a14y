---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { listCaseStudies, caseStudyUrl } from '~/lib/case-study-data';
import { getBulkLeaderboard, getDefaultBulkVersion } from '~/lib/bulk-data';
import { STATE_OF_AGENT_READABILITY_PUBLISHED, formatPublishDate } from '~/lib/research-meta';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const studies = listCaseStudies();

// Standalone survey article (not a case study). Headline numbers are live so the
// blurb never drifts from the data; the date is the fixed publish date.
const bulkVersion = getDefaultBulkVersion();
const bulkLb = bulkVersion ? getBulkLeaderboard(bulkVersion) : null;
const bulkTotal = bulkLb?.totalScanned ?? 0;
const bulkScores = bulkLb ? bulkLb.entries.map((e) => e.s).sort((a, b) => a - b) : [];
const bulkMedian = bulkScores.length ? bulkScores[Math.floor(bulkScores.length / 2)] : 0;
const surveyDate = formatPublishDate(STATE_OF_AGENT_READABILITY_PUBLISHED);
const surveyUrl = `${base}/research/state-of-agent-readability/`;
---

<BaseLayout
  title="Research · a14y"
  description="Empirical findings about agent readability. How much does raising a site's a14y score actually save an AI agent? Measured results from running real coding agents against real websites at different scores."
>
  <section class="hero hero--compact" aria-labelledby="research-heading">
    <div class="hero-text" style="grid-column: 1 / -1;">
      <div class="eyebrow">
        <span class="eyebrow-pin">research</span>
        <span>Empirical findings about agent readability</span>
      </div>
      <h1 id="research-heading">Research</h1>
      <p class="lead">
        Measured results from running real AI agents against real
        websites at different a14y scores.
      </p>
    </div>
  </section>

  <section class="section" aria-label="Case studies">
    <ul class="case-study-list" role="list">
      {bulkLb && (
        <li class="case-study-card">
          <div class="case-study-card-meta">
            <span class="eyebrow-pin">v{bulkVersion}</span>
            <time datetime={STATE_OF_AGENT_READABILITY_PUBLISHED}>{surveyDate}</time>
          </div>
          <h3 class="case-study-card-title">
            <a href={surveyUrl}>The State of Agent Readability on the Web</a>
          </h3>
          <p class="case-study-card-tldr">
            We scored the {bulkTotal.toLocaleString('en-US')} most-visited websites for how ready they are for AI
            agents. The median scores {bulkMedian} of 100, not one scored "excellent," and the agent-era layer
            (llms.txt, AGENTS.md, markdown mirrors) is mostly missing or only half-built.
          </p>
          <p class="case-study-card-cta">
            <a href={surveyUrl}>Read the survey →</a>
          </p>
        </li>
      )}
      {studies.map((cs) => (
        <li class="case-study-card">
          <div class="case-study-card-meta">
            <span class="eyebrow-pin">v{cs.scorecardVersion}</span>
            <time datetime={cs.publishedAt}>{formatPublishDate(cs.publishedAt)}</time>
          </div>
          <h3 class="case-study-card-title">
            <a href={caseStudyUrl(cs.slug, base)}>
              {cs.title}
            </a>
          </h3>
          <p class="case-study-card-tldr">{cs.tldr}</p>
          <p class="case-study-card-cta">
            <a href={caseStudyUrl(cs.slug, base)}>
              Read the case study →
            </a>
          </p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .case-study-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 24px;
  }

  .case-study-card {
    padding: 32px 0;
    border-top: 1px solid var(--border);
  }

  .case-study-card:last-child {
    border-bottom: 1px solid var(--border);
  }

  .case-study-card-meta {
    display: flex;
    gap: 12px;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .case-study-card-title {
    font-size: 24px;
    line-height: 1.25;
    margin: 0 0 12px;
  }

  .case-study-card-title a {
    color: var(--text);
    text-decoration: none;
  }

  .case-study-card-title a:hover {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .case-study-card-tldr {
    color: var(--text-muted);
    margin: 0 0 16px;
    max-width: 65ch;
  }

  .case-study-card-cta {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 14px;
  }
</style>
