---
import { getEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';

const entry = await getEntry('pages', 'glossary');
if (!entry) throw new Error('Missing pages/glossary content entry');
const { Content } = await entry.render();
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
>
  <section class="hero">
    <div class="hero-text" style="grid-column: 1 / -1;">
      <div class="eyebrow">
        <span class="eyebrow-pin">terms</span>
        <span>vocabulary used across the spec, CLI, and extension</span>
      </div>
      <h1>Glossary</h1>
      <p class="lead">
        The vocabulary used by the a14y scorecard, CLI, and Chrome
        extension. If a term in the docs feels overloaded, look here first.
      </p>
    </div>
  </section>

  <Content />
</BaseLayout>
