---
import { getEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';

const entry = await getEntry('pages', 'privacy');
if (!entry) throw new Error('Missing pages/privacy content entry');
const { Content } = await entry.render();

// Build-time stamp. Astro is SSG so this value is fixed per deploy:
// the freshness signal readers (and agents) look for.
const lastUpdated = new Date().toISOString().slice(0, 10);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
>
  <section class="hero">
    <div class="hero-text" style="grid-column: 1 / -1;">
      <div class="eyebrow">
        <span class="eyebrow-pin">policy</span>
        <span>last updated {lastUpdated}</span>
      </div>
      <h1>Privacy</h1>
      <p class="lead">
        We collect a small amount of anonymous usage data, on by default,
        to help us improve a14y. We never collect personally identifiable
        information, the URLs you audit, or the content of any page you
        visit with the extension or CLI. You can turn telemetry off on
        every surface, and the controls are listed below.
      </p>
    </div>
  </section>

  <Content />

  <script is:inline>
    (function () {
      var KEY = 'a14y:ga-opt-out';
      var btn = document.getElementById('ga-opt-out-toggle');
      var status = document.getElementById('ga-opt-out-status');
      if (!btn || !status) return;
      function isOptedOut() {
        try { return localStorage.getItem(KEY) === '1'; } catch (e) { return false; }
      }
      function render() {
        if (isOptedOut()) {
          btn.textContent = btn.getAttribute('data-off-label') || 'Enable analytics on this site';
          status.textContent = 'Analytics is disabled on this site. Reload to confirm no GA script loads.';
        } else {
          btn.textContent = btn.getAttribute('data-on-label') || 'Disable analytics on this site';
          status.textContent = '';
        }
      }
      btn.addEventListener('click', function () {
        try {
          if (isOptedOut()) localStorage.removeItem(KEY);
          else localStorage.setItem(KEY, '1');
        } catch (e) {
          status.textContent = 'Could not persist preference (localStorage unavailable).';
          return;
        }
        render();
      });
      render();
    })();
  </script>

  <style>
    .ga-opt-out-status {
      margin-left: 10px;
      font-size: 13px;
      color: var(--text-muted);
    }
  </style>
</BaseLayout>
