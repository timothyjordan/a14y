---
import { getEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getLatestScorecardVersion, getScorecardByVersion } from '~/lib/scorecard-data';

const entry = await getEntry('pages', 'spec');
if (!entry) throw new Error('Missing pages/spec content entry');
const { Content } = await entry.render();

const latest = getLatestScorecardVersion();
const released = getScorecardByVersion(latest).releasedAt;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
>
  <section class="hero">
    <div class="hero-text" style="grid-column: 1 / -1;">
      <div class="eyebrow">
        <span class="eyebrow-pin">spec</span>
        <span>v{latest} · released {released}</span>
      </div>
      <h1>Agent readability, defined.</h1>
      <p class="lead">
        An open set of practices that make any website discoverable,
        parseable, and comprehensible to AI agents. The scorecard
        operationalizes the spec into pass-or-fail checks. The tools
        run those checks against real sites.
      </p>
    </div>
  </section>

  <Content />
</BaseLayout>
