---
import '~/styles/global.css';
import VersionSelector from '~/components/VersionSelector.astro';
import { getLatestScorecardVersion } from '~/lib/scorecard-data';

interface Props {
  title: string;
  description?: string;
  /** Active scorecard version — passed to the VersionSelector. */
  scorecardVersion?: string;
}

const {
  title,
  description = 'Agent readability scorecard — documentation, detection rules, and implementation notes.',
  scorecardVersion = getLatestScorecardVersion(),
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Canonical URL for this page. Astro.site is the deployment origin
// (e.g. https://timothyjordan.github.io), Astro.url.pathname includes
// the configured `base` (e.g. /agentready/scorecards/0.2.0/), so the
// concatenation gives the fully-qualified canonical address. Used by
// html.canonical-link, html.json-ld breadcrumb anchors, and the
// markdown alternate link below.
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

// Markdown mirror lives next to each HTML page with a `.md` suffix
// in place of the trailing slash. The actual mirror files are
// generated by the markdown-mirrors integration in Phase 2-F.
const trimmedPath = Astro.url.pathname.replace(/\/$/, '') || '/index';
const mirrorHref = new URL(`${trimmedPath}.md`, Astro.site).toString();

// Build a BreadcrumbList from the URL pathname so JSON-LD consumers
// know exactly where this page sits in the site hierarchy. The first
// item is always the docs landing; subsequent items are derived from
// the path segments after `base`.
const baseSegments = base.replace(/^\//, '').split('/').filter(Boolean);
const allSegments = Astro.url.pathname.replace(/^\//, '').split('/').filter(Boolean);
const trailingSegments = allSegments.slice(baseSegments.length);
const breadcrumbItems = [
  {
    '@type': 'ListItem',
    position: 1,
    name: 'agentready',
    item: new URL(`${base}/`, Astro.site).toString(),
  },
  ...trailingSegments.map((segment, i) => {
    const subPath = '/' + [...baseSegments, ...trailingSegments.slice(0, i + 1)].join('/') + '/';
    return {
      '@type': 'ListItem',
      position: i + 2,
      name: segment,
      item: new URL(subPath, Astro.site).toString(),
    };
  }),
];

// dateModified is fixed at build time. Astro is SSG so this is
// deterministic per deploy and changes whenever the build runs,
// which is exactly the freshness signal agents want.
const dateModified = new Date().toISOString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: canonicalUrl,
  dateModified,
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbItems,
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/markdown" href={mirrorHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="article" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href={`${base}/`}>agentready</a>
        <nav class="site-nav">
          <a href={`${base}/scorecards/`}>Scorecards</a>
          <a href={`${base}/glossary/`}>Glossary</a>
          <a href="https://github.com/timothyjordan/agentready">GitHub</a>
          <VersionSelector current={scorecardVersion} />
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      agentready scorecard docs · <a href={`${base}/glossary/`}>glossary</a> · <a href="https://timothyjordan.com/blog/2026/03/23/agent-readability-spec.html">spec</a> · <a href="https://github.com/timothyjordan/agentready">source</a>
    </footer>
  </body>
</html>
