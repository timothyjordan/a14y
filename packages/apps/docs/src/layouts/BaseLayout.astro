---
import '~/styles/global.css';
import Analytics from '~/components/Analytics.astro';
import ScorecardSubHeader from '~/components/ScorecardSubHeader.astro';
import { getLatestScorecardVersion, getScorecardByVersion } from '~/lib/scorecard-data';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

interface Props {
  title: string;
  description?: string;
  /** Active scorecard version. Passed to the VersionSelector on scorecard pages. */
  scorecardVersion?: string;
  /** Show the version selector in the header. Only scorecard pages need it. */
  showVersionSelector?: boolean;
  /** Opt into a wider content container (used by the landing). */
  wide?: boolean;
  /**
   * Path or absolute URL for the OG / Twitter share image. Defaults to
   * the generic site lockup at `/brand/og-image.png`; per-page handlers
   * (e.g. `/leaderboard/<slug>/`) point at their own per-site PNG.
   */
  ogImage?: string;
}

const {
  title,
  description = 'Agent readability for the web. An open spec, a versioned scorecard, and the tools (CLI plus Chrome extension) that score any website for how well AI agents can discover, parse, and comprehend it.',
  scorecardVersion = getLatestScorecardVersion(),
  showVersionSelector = false,
  wide = false,
  ogImage = `${base}/brand/og-image.png`,
} = Astro.props;

const latest = getLatestScorecardVersion();
const latestReleased = getScorecardByVersion(latest).releasedAt;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

const trimmedPath = Astro.url.pathname.replace(/\/$/, '') || '/index';
const mirrorHref = new URL(`${trimmedPath}.md`, Astro.site).toString();

const baseSegments = base.replace(/^\//, '').split('/').filter(Boolean);
const allSegments = Astro.url.pathname.replace(/^\//, '').split('/').filter(Boolean);
const trailingSegments = allSegments.slice(baseSegments.length);
const breadcrumbItems = [
  {
    '@type': 'ListItem',
    position: 1,
    name: 'a14y',
    item: new URL(`${base}/`, Astro.site).toString(),
  },
  ...trailingSegments.map((segment, i) => {
    const subPath = '/' + [...baseSegments, ...trailingSegments.slice(0, i + 1)].join('/') + '/';
    return {
      '@type': 'ListItem',
      position: i + 2,
      name: segment,
      item: new URL(subPath, Astro.site).toString(),
    };
  }),
];

const dateModified = new Date().toISOString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      name: title,
      description,
      url: canonicalUrl,
      dateModified,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbItems,
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/markdown" href={mirrorHref} />
    <link rel="agent-skills" href={new URL(`${base}/.well-known/agent-skills/index.json`, Astro.site).toString()} />
    <link rel="icon" type="image/svg+xml" href={`${base}/brand/favicon.svg`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta name="theme-color" content="oklch(0.985 0.008 90)" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="oklch(0.16 0.025 268)" media="(prefers-color-scheme: dark)" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible+Next:ital,wght@0,200..800;1,200..800&family=JetBrains+Mono:ital,wght@0,400..700;1,400..700&display=swap"
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <Analytics />
    <script is:inline>
      // Set data-theme before first paint to prevent FOUC. Light is
      // the default; OS preference is ignored (the user's explicit
      // choice via the toggle, persisted to localStorage, wins).
      (function () {
        try {
          var stored = localStorage.getItem('a14y-theme');
          var theme = stored === 'dark' ? 'dark' : 'light';
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href={`${base}/`} aria-label="a14y home">
          <img
            class="brand-mark brand-mark--light"
            src={`${base}/brand/logo-mark.svg`}
            width="28"
            height="28"
            alt=""
          />
          <img
            class="brand-mark brand-mark--dark"
            src={`${base}/brand/logo-mark--dark.svg`}
            width="28"
            height="28"
            alt=""
            aria-hidden="true"
          />
          <span class="brand-word">a14y</span>
          <span class="brand-version" aria-label={`Scorecard ${latest}`}>v{latest}</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href={`${base}/spec/`}>Spec</a>
          <a href={`${base}/scorecards/`}>Scorecard</a>
          <a href={`${base}/#tools`} data-secondary>Tools</a>
          <a href={`${base}/leaderboard/`}>Leaderboard</a>
          <a href={`${base}/press/`} data-secondary>Press</a>
          <a href="https://github.com/timothyjordan/a14y" rel="noopener" data-secondary>GitHub</a>
          <button
            type="button"
            class="theme-toggle"
            aria-label="Toggle dark mode"
            data-theme-toggle
          >
            <svg
              class="icon-moon"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
            <svg
              class="icon-sun"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2" />
              <path d="M12 20v2" />
              <path d="m4.93 4.93 1.41 1.41" />
              <path d="m17.66 17.66 1.41 1.41" />
              <path d="M2 12h2" />
              <path d="M20 12h2" />
              <path d="m4.93 19.07 1.41-1.41" />
              <path d="m17.66 6.34 1.41-1.41" />
            </svg>
          </button>
        </nav>
      </div>
    </header>
    {showVersionSelector && <ScorecardSubHeader version={scorecardVersion} />}
    <main class={`container${wide ? ' container--wide' : ''}`}>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer-inner">
        <div class="colophon">
          <h4>a14y</h4>
          <p>An open spec, a versioned scorecard, and the tools that measure how readable any site is to AI agents.</p>
          <div class="colophon-meta">
            scorecard v{latest} · released {latestReleased} · Apache-2.0
          </div>
          <div class="site-footer-credit">
            <span>Created by <a href="https://timothyjordan.com" rel="noopener">Timothy Jordan</a></span>
            <a
              class="site-footer-credit-icon"
              href="https://x.com/timothyjordan"
              rel="noopener"
              aria-label="Timothy Jordan on X"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                width="15"
                height="15"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            </a>
            <a
              class="site-footer-credit-icon"
              href="https://www.linkedin.com/in/captaintimothy/"
              rel="noopener"
              aria-label="Timothy Jordan on LinkedIn"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                width="16"
                height="16"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.37V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z" />
              </svg>
            </a>
          </div>
        </div>
        <div class="footer-col">
          <h4>Read</h4>
          <ul>
            <li><a href={`${base}/spec/`}>Spec</a></li>
            <li><a href={`${base}/scorecards/`}>Scorecard</a></li>
            <li><a href={`${base}/glossary/`}>Glossary</a></li>
            <li><a href={`${base}/release-notes/`}>Release notes</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Use</h4>
          <ul>
            <li><a href={`${base}/chrome-extension/`}>Chrome extension</a></li>
            <li><a href="https://www.npmjs.com/package/a14y" rel="noopener">npm</a></li>
            <li><a href="https://github.com/timothyjordan/a14y" rel="noopener">Source</a></li>
            <li><a href={`${base}/privacy/`}>Privacy</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>For agents</h4>
          <ul>
            <li><a href={`${base}/llms.txt`}>llms.txt</a></li>
            <li><a href={`${base}/AGENTS.md`}>AGENTS.md</a></li>
            <li><a href={`${base}/sitemap.md`}>sitemap.md</a></li>
            <li><a href={`${base}/.well-known/agent-skills/index.json`}>agent-skills</a></li>
          </ul>
        </div>
      </div>
    </footer>
    <script is:inline>
      // Theme toggle plus clipboard-copy handlers. Kept inline so the
      // handlers bind on every page without an extra network round-trip.
      (function () {
        var btn = document.querySelector('[data-theme-toggle]');
        if (btn) {
          var sync = function () {
            var current = document.documentElement.dataset.theme || 'light';
            btn.setAttribute('aria-pressed', current === 'dark' ? 'true' : 'false');
          };
          sync();
          btn.addEventListener('click', function () {
            var current = document.documentElement.dataset.theme || 'light';
            var next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.dataset.theme = next;
            try { localStorage.setItem('a14y-theme', next); } catch (e) {}
            sync();
          });
        }

        document.querySelectorAll('[data-copy]').forEach(function (el) {
          el.addEventListener('click', function () {
            var text = el.getAttribute('data-copy') || '';
            if (!text || !navigator.clipboard) return;
            navigator.clipboard.writeText(text).then(function () {
              var prev = el.textContent;
              el.setAttribute('data-state', 'copied');
              el.textContent = 'Copied';
              setTimeout(function () {
                el.removeAttribute('data-state');
                el.textContent = prev || 'Copy';
              }, 1400);
            }).catch(function () {});
          });
        });
      })();
    </script>
  </body>
</html>
