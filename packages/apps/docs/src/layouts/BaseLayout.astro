---
import '~/styles/global.css';
import Analytics from '~/components/Analytics.astro';
import ScorecardSubHeader from '~/components/ScorecardSubHeader.astro';
import { getLatestScorecardVersion } from '~/lib/scorecard-data';

interface Props {
  title: string;
  description?: string;
  /** Active scorecard version — passed to the VersionSelector on scorecard pages. */
  scorecardVersion?: string;
  /** Show the version selector in the header. Only scorecard pages need it. */
  showVersionSelector?: boolean;
  /** Opt into a wider content container (used by the landing). */
  wide?: boolean;
}

const {
  title,
  description = 'Agent readability for the web — the open spec, the versioned scorecard, and the tools (CLI + Chrome extension) that score any website for how well AI agents can discover, parse, and comprehend it.',
  scorecardVersion = getLatestScorecardVersion(),
  showVersionSelector = false,
  wide = false,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Canonical URL for this page. Astro.site is the deployment origin
// (https://a14y.dev), Astro.url.pathname gives the path relative to the
// site, so the concatenation yields the fully-qualified canonical
// address. Used by html.canonical-link, json-ld breadcrumb anchors,
// and the markdown alternate link below.
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();

// Markdown mirror lives next to each HTML page with a `.md` suffix in
// place of the trailing slash. The actual mirror files are generated
// by the markdown-mirrors integration.
const trimmedPath = Astro.url.pathname.replace(/\/$/, '') || '/index';
const mirrorHref = new URL(`${trimmedPath}.md`, Astro.site).toString();

// Build a BreadcrumbList from the URL pathname so JSON-LD consumers
// know exactly where this page sits in the site hierarchy. The first
// item is always the docs landing; subsequent items are derived from
// the path segments after `base`.
const baseSegments = base.replace(/^\//, '').split('/').filter(Boolean);
const allSegments = Astro.url.pathname.replace(/^\//, '').split('/').filter(Boolean);
const trailingSegments = allSegments.slice(baseSegments.length);
const breadcrumbItems = [
  {
    '@type': 'ListItem',
    position: 1,
    name: 'a14y',
    item: new URL(`${base}/`, Astro.site).toString(),
  },
  ...trailingSegments.map((segment, i) => {
    const subPath = '/' + [...baseSegments, ...trailingSegments.slice(0, i + 1)].join('/') + '/';
    return {
      '@type': 'ListItem',
      position: i + 2,
      name: segment,
      item: new URL(subPath, Astro.site).toString(),
    };
  }),
];

// dateModified is fixed at build time. Astro is SSG so this is
// deterministic per deploy and changes whenever the build runs,
// which is exactly the freshness signal agents want.
const dateModified = new Date().toISOString();

// Use @graph so the BreadcrumbList sits as a sibling of the WebPage
// node rather than nested under `breadcrumb:`. The a14y
// json-ld.breadcrumb check walks JSON-LD nodes following @graph; the
// nested breadcrumb shape was invisible to it.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      name: title,
      description,
      url: canonicalUrl,
      dateModified,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbItems,
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/markdown" href={mirrorHref} />
    <link rel="icon" type="image/svg+xml" href={`${base}/brand/favicon.svg`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:image" content={new URL(`${base}/brand/og-image.png`, Astro.site).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL(`${base}/brand/og-image.png`, Astro.site).toString()} />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0b0b0c" media="(prefers-color-scheme: dark)" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <Analytics />
    <script is:inline>
      // Set data-theme before first paint to prevent FOUC. Light is
      // the default; OS preference is ignored — the user's explicit
      // choice (sun/moon toggle, persisted to localStorage) wins.
      (function () {
        try {
          var stored = localStorage.getItem('a14y-theme');
          var theme = stored === 'dark' ? 'dark' : 'light';
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="brand" href={`${base}/`} aria-label="a14y home">
          <img class="brand-mark" src={`${base}/brand/logo-mark.svg`} width="28" height="28" alt="" />
          <span class="brand-word">a14y</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href={`${base}/spec/`}>Spec</a>
          <a href={`${base}/scorecards/`}>Scorecard</a>
          <a href={`${base}/#tools`}>Tools</a>
          <a href="https://github.com/timothyjordan/a14y" rel="noopener">GitHub</a>
          <button
            type="button"
            class="theme-toggle"
            aria-label="Toggle dark mode"
            data-theme-toggle
          >
            <svg
              class="icon-moon"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
            <svg
              class="icon-sun"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2" />
              <path d="M12 20v2" />
              <path d="m4.93 4.93 1.41 1.41" />
              <path d="m17.66 17.66 1.41 1.41" />
              <path d="M2 12h2" />
              <path d="M20 12h2" />
              <path d="m4.93 19.07 1.41-1.41" />
              <path d="m17.66 6.34 1.41-1.41" />
            </svg>
          </button>
        </nav>
      </div>
    </header>
    {showVersionSelector && <ScorecardSubHeader version={scorecardVersion} />}
    <main class={`container${wide ? ' container--wide' : ''}`}>
      <slot />
    </main>
    <footer class="site-footer">
      a14y · <a href={`${base}/spec/`}>spec</a> · <a href={`${base}/scorecards/`}>scorecard</a> · <a href={`${base}/glossary/`}>glossary</a> · <a href={`${base}/privacy/`}>privacy</a> · <a href="https://github.com/timothyjordan/a14y" rel="noopener">source</a>
    </footer>
    <script is:inline>
      // Theme toggle + clipboard-copy handlers. Kept inline so the
      // handlers bind on every page without an extra network round-trip.
      (function () {
        var btn = document.querySelector('[data-theme-toggle]');
        if (btn) {
          var sync = function () {
            var current = document.documentElement.dataset.theme || 'light';
            btn.setAttribute('aria-pressed', current === 'dark' ? 'true' : 'false');
          };
          sync();
          btn.addEventListener('click', function () {
            var current = document.documentElement.dataset.theme || 'light';
            var next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.dataset.theme = next;
            try { localStorage.setItem('a14y-theme', next); } catch (e) {}
            sync();
          });
        }

        document.querySelectorAll('[data-copy]').forEach(function (el) {
          el.addEventListener('click', function () {
            var text = el.getAttribute('data-copy') || '';
            if (!text || !navigator.clipboard) return;
            navigator.clipboard.writeText(text).then(function () {
              var prev = el.textContent;
              el.setAttribute('data-state', 'copied');
              el.textContent = 'Copied';
              setTimeout(function () {
                el.removeAttribute('data-state');
                el.textContent = prev || 'Copy';
              }, 1400);
            }).catch(function () {});
          });
        });
      })();
    </script>
  </body>
</html>
