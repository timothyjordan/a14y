{
  "name": "@a14y/docs",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "predev": "node ../../../scripts/inject-telemetry-config.mjs docs",
    "build": "astro build",
    "prebuild": "node ../../../scripts/inject-telemetry-config.mjs docs && tsx scripts/build-site-og.ts",
    "preview": "node scripts/preview.mjs",
    "pretest": "node ../../../scripts/inject-telemetry-config.mjs docs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "build:og": "node scripts/build-og-image.mjs",
    "build:site-og": "tsx scripts/build-site-og.ts",
    "press:capture": "node scripts/capture-press-cli.mjs",
    "predev:baseline": "node ../../../scripts/inject-telemetry-config.mjs docs && node scripts/clean-baseline-public.mjs",
    "dev:baseline": "A14Y_BASELINE=1 astro dev --port 4322",
    "prebuild:baseline": "node ../../../scripts/inject-telemetry-config.mjs docs && node scripts/clean-baseline-public.mjs",
    "build:baseline": "A14Y_BASELINE=1 astro build --outDir dist-baseline",
    "preview:baseline": "DIST_DIR=dist-baseline PORT=4322 node scripts/preview.mjs"
  },
  "dependencies": {
    "@a14y/core": "*",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^4.16.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@playwright/test": "^1.61.1",
    "@types/turndown": "^5.0.6",
    "playwright": "^1.61.1",
    "sharp": "^0.33.5",
    "tsx": "^4.19.2",
    "turndown": "^7.2.4",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1"
  }
}
