{
  "name": "@a14y/core",
  "version": "0.3.0",
  "description": "Shared engine for the a14y agent-readability scorer. Powers the CLI and Chrome extension.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timothyjordan/a14y.git",
    "directory": "packages/core"
  },
  "homepage": "https://timothyjordan.github.io/a14y/",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.esm.json",
    "test": "vitest run",
    "prepack": "node ../../scripts/build-readmes.mjs"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "fast-xml-parser": "^5.5.10",
    "marked": "^17.0.6",
    "p-queue": "^7.4.1",
    "robots-parser": "^3.0.1"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^1.6.1"
  }
}
