# Build-time telemetry config for cli / extension / docs.
# Copy this file to `.env.local` (gitignored) and fill in real values, or
# export them as shell env vars before `npm run build`. The prebuild step
# (scripts/inject-telemetry-config.mjs) reads these and bakes them into a
# generated TypeScript module that ships with the build. When absent, the
# generated module exports nulls and telemetry silently disables itself.
#
# CI sets these via repo Secrets in .github/workflows/*.yml; values in the
# environment always win over .env.local.

GA4_MEASUREMENT_ID=
GA4_MP_API_SECRET=
