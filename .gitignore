# Node.js
node_modules
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.pnpm/
.yarn/

# Build artifacts
dist/
dist-baseline/
build/
.next/ # if using Next.js

# Dependency directories for workspaces
packages/*/node_modules/
packages/*/dist/
packages/*/dist-baseline/
packages/apps/docs/dist-baseline/

# Editor/IDE files
.vscode/
.idea/
.DS_Store
*.sublime-project
*.sublime-workspace

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Coverage reports
coverage/

# Playwright E2E artifacts
test-results/
playwright-report/
.playwright/

# testbotpro adversarial-test work dir (scratch; generated tests are promoted
# into each package's test/ dir and committed there)
.testbotpro/

# Misc
*.tgz
.npmrc
.yarnrc
.tool-versions

# Astro generated (docs workspace)
packages/apps/docs/.astro/
packages/apps/docs/src/env.d.ts

# Build-time injected telemetry config (provider keys)
packages/apps/cli/src/generated/
packages/apps/extension/src/generated/
packages/apps/docs/src/generated/
# Generated by docs discovery-files integration on dev/build
packages/apps/docs/public/llms.txt
packages/apps/docs/public/AGENTS.md
packages/apps/docs/public/sitemap.md
packages/apps/docs/public/sitemap.xml
packages/apps/docs/public/robots.txt
packages/apps/docs/public/.well-known/

# Generated by scripts/build-site-og.mjs (per-site OG screenshots
# + incremental cache manifest). Regenerated at build time.
packages/apps/docs/public/leaderboard/
